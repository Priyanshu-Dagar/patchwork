<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <h1>Patchwork</h1>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <% if (currentUser) { %>
                    <li><a href="/dashboard">Dashboard</a></li>
                    <li><a href="/auth/logout">Logout</a></li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register">Register</a></li>
                <% } %>
            </ul>
        </nav>
    </header>
    <main style="text-align: center;">
        <img src="/images/logo.webp" alt="Patchwork Logo" style="width: 150px; margin-bottom: 20px;">
        <h2>Connect. Collaborate. Learn.</h2>
        <p style="font-size: 1.2rem; color: #666;">The community-driven skill exchange platform built on project-based learning.</p>
        <div style="margin-top: 40px;">
            <a href="/register" class="btn" style="padding: 15px 40px; font-size: 1.1rem;">Join the Network</a>
            <p style="margin-top: 15px;">Already a member? <a href="/login">Sign in</a></p>
        </div>
    </main>
    <footer>
        <p>&copy; 2026 Patchwork Project</p>
    </footer>
</body>
</html>
